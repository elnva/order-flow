# Example environment config. Copy to `.env` and fill in real values.
# `.env` is git-ignored — NEVER commit real keys.
#
# NOTE: The frontend has no build step today, so there is no automatic .env loading yet.
# This file documents the config contract for when a backend (see docs/rfc/0001) is added.
# Until then, the Supabase *anon* key (publishable, protected by Row Level Security) would
# be placed in a small frontend config object — see the RFC §8.4.

# --- Supabase (publishable in the browser; safe ONLY because RLS restricts it) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-publishable-key

# --- Server-side only. MUST NOT be shipped to the browser or committed. ---
# SUPABASE_SERVICE_ROLE_KEY=keep-this-only-in-the-supabase-dashboard-or-a-server
